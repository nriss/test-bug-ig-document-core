       fhir:definition [ fhir:v "Conformité FR-Traitement (CI-SIS)" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:frTraitement.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.2.250.1.213.1.1.3.42"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:ihePosologieStructuree" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "ihePosologieStructuree" ] ;
       fhir:short [ fhir:v "Conformité Posologie structurée" ] ;
       fhir:definition [ fhir:v "Conformité Posologie structurée" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:ihePosologieStructuree.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.3.6.1.4.1.19376.1.9.1.3.6"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAdministrationNormal" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "iheModeAdministrationNormal" ] ;
       fhir:short [ fhir:v "Mode d'administration : normal. Administration sans précaution particulière à prendre. Dans ce cas, ne pas utiliser d'entrée subordonnée." ] ;
       fhir:definition [ fhir:v "Mode d'administration : normal" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAdministrationNormal.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.3.6.1.4.1.19376.1.5.3.1.4.7.1"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAdministrationDosesProgressives" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "iheModeAdministrationDosesProgressives" ] ;
       fhir:short [ fhir:v "Mode d'administration : doses progressives. Administration pour les médicamments dont la posologie optimale (ou l'arrêt) n'est obtenue que progressivement, par paliers. Par exemple :\n- 0.5 mg par jour pendant 3 jours ;\n- puis 1 mg par jour les 5 jours suivants ;\n- puis 2 mg par jour.\nSouvent, en particulier lorsque l'arrêt brusque du traitement peut avoir des conséquences négatives, les doses sont réduites progressivement. Les doses peuvent être ajustées en modifiant la fréquence de la dose, la quantité de la dose, ou les deux. Lorsque la fréquence de la dose est simplement ajustée (par ex. 5 mg de prednisone deux fois par jour pendant trois jours, puis 5 mg par jour pendant trois jours, puis 5 mg tous les deux jours), \nune seule entrée Traitement est nécessaire et les différentes fréquences sont enregistrées dans l'élement. Lorsque la dose varie (par ex. 15 mg de prednisone par jour pendant trois jours, puis 10 mg par jour pendant trois jours, puis 5 mg par jour pendant trois jours), un composant subordonné doit être créé pour chaque dose." ] ;
       fhir:definition [ fhir:v "Mode d'administration : doses progressives" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAdministrationDosesProgressives.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.3.6.1.4.1.19376.1.5.3.1.4.8"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAdministrationDosesFractionnees" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "iheModeAdministrationDosesFractionnees" ] ;
       fhir:short [ fhir:v "Mode d'administration : doses fractionnées. Administration de médicaments dont la posologie varie d'un jour sur l'autre. Par exemple : Coumadine : ¼ cp les jours pairs et ½ cp les jours impairs. \nUne dose fractionnée est souvent utilisée lorsque différentes doses sont administrées à différents moments (par ex. à différents moments de la journée ou sur des jours différents). Il peut s'agir de tenir compte de différents taux métaboliques à différents moments de la journée ou simplement d'aborder les carences du boîtage des médicaments (par ex. 2 mg de Coumadin les jours pairs et 2,5 mg les jours impairs parce que la Coumadine n'existe pas sous une forme posologique à 2,25 mg).\nDans ce cas, une entrée subordonnée  est requise pour chaque dose fractionnée." ] ;
       fhir:definition [ fhir:v "Mode d'administration : doses fractionnées" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAdministrationDosesFractionnees.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.3.6.1.4.1.19376.1.5.3.1.4.9"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAdministrationDosesConditionnelles" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "iheModeAdministrationDosesConditionnelles" ] ;
       fhir:short [ fhir:v "Mode d'administration : doses conditionnelles. Administration en fonction d'un événement (typiquement dosage de la glycémie pour les diabétiques). \nUne dose conditionnelle est souvent utilisée lorsque la quantité de la dose diffère en fonction de certaines mesures (p. ex. une dose d'insuline en fonction du taux de glycémie). Dans ce cas, une entrée subordonnée  est requise pour chaque dose conditionnelle." ] ;
       fhir:definition [ fhir:v "Mode d'administration : doses conditionnelles" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAdministrationDosesConditionnelles.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.3.6.1.4.1.19376.1.5.3.1.4.10"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAadministrationDosesCombinees" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "iheModeAadministrationDosesCombinees" ] ;
       fhir:short [ fhir:v "Mode d'administration : doses combinées. Administration de médicaments combinés à d'autres dans le contexte d'une même prise. Une association médicamenteuse est composée de deux ou plusieurs autres médicaments. \nCeux-ci peuvent être préemballés, comme l'Acuilix, qui est une combinaison d'hydrochlorothiazide et de quinapril dans des proportions prédéfinies, ou préparés par un pharmacien. \nDans le cas d'une association médicamenteuse préemballée, il suffit de fournir le nom du produit médicamenteux d'association et la désignation de sa concentration dans une seule entrée . L'information posologique doit ensuite être enregistrée sous la forme d'un simple comptage des unités d'administration.\nDans le cas d'un mélange préparé, la description du mélange doit être fournie en tant que nom du produit, dans l'entrée . Cette entrée peut, mais ce n'est pas obligatoire, avoir des entrées subordonnées sous cette entrée pour enregistrer les composants du mélange." ] ;
       fhir:definition [ fhir:v "Mode d'administration : doses combinées" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAadministrationDosesCombinees.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.3.6.1.4.1.19376.1.5.3.1.4.11"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAadministrationDosesDebutDiffere" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "iheModeAadministrationDosesDebutDiffere" ] ;
       fhir:short [ fhir:v "Mode d'administration : doses à début différé. Administration de médicaments dont le début est différée et ne peut être calculés. Exemples : 3 jours avant le voyage, 1 jour avant une intervention. Dans ce cas, ne pas utiliser de  subordonné." ] ;
       fhir:definition [ fhir:v "Mode d'administration : doses à début différé" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:iheModeAadministrationDosesDebutDiffere.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.3.6.1.4.1.19376.1.5.3.1.4.21"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:frTraitementLongCours" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "frTraitementLongCours" ] ;
       fhir:short [ fhir:v "Traitement au long cours" ] ;
       fhir:definition [ fhir:v "Traitement au long cours" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:frTraitementLongCours.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.2.250.1.213.1.1.3.42.3"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:frTraitementAigu" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "frTraitementAigu" ] ;
       fhir:short [ fhir:v "Traitement aigu" ] ;
       fhir:definition [ fhir:v "Traitement aigu" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:frTraitementAigu.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.2.250.1.213.1.1.3.42.4"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.classCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.classCode" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.moodCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.moodCode" ] ;
       fhir:short [ fhir:v "Si le traitement a déjà été administré\nou si information rapportée par le patient\nou si aucun traitement : moodCode='EVN' ;     \nSi le traitement est en attente d'administration : moodCode='INT'" ] ;
       fhir:definition [ fhir:v "Si le traitement a déjà été administré ou si information rapportée par le patient ou si aucun traitement; si le traitement est en attente d'administration" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.id" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.id" ] ;
       fhir:short [ fhir:v "Identifiant de l'entrée" ] ;
       fhir:definition [ fhir:v "Identifiant de l'entrée" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.code" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.code" ] ;
       fhir:short [ fhir:v "Acte ou situation" ] ;
       fhir:definition [ fhir:v "Acte ou situation" ] ;
       fhir:mustSupport [ fhir:v true ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/ValueSet/fr-valueset-code-traitement"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/ValueSet/fr-valueset-code-traitement>
         ]
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.code.code" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.code.code" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.code.codeSystem" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.code.codeSystem" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.code.displayName" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.code.displayName" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.text" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.text" ] ;
       fhir:short [ fhir:v "Partie narrative de l’entrée" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.text.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.text.reference" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.statusCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.statusCode" ] ;
       fhir:short [ fhir:v "Statut de l’entrée : Fixé à la valeur 'completed' car l’administration a déjà été réalisée ou ordonnée" ] ;
       fhir:definition [ fhir:v "Statut de l’entrée" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.statusCode.code" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.statusCode.code" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "completed"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.effectiveTime" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.effectiveTime" ] ;
       fhir:slicing [
         fhir:discriminator ( [
           fhir:type [ fhir:v "pattern" ] ;
           fhir:path [ fhir:v "operator" ]
         ] ) ;
         fhir:rules [ fhir:v "open" ]
       ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.effectiveTime:effectiveTimeDuree" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.effectiveTime" ] ;
       fhir:sliceName [ fhir:v "effectiveTimeDuree" ] ;
       fhir:short [ fhir:v "Durée de traitement" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "fr-operator-not-a" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "operator doit être différent de A" ] ;
         fhir:expression [ fhir:v "operator != 'A'" ] ;
         fhir:source [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement>
         ]
       ] [
         fhir:key [ fhir:v "fr-effectiveTime-duree-type" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "La durée doit être IVL-TS" ] ;
         fhir:expression [ fhir:v "is(IVL_TS)" ] ;
         fhir:source [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement>
         ]
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.effectiveTime:effectiveTimeFrequence" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.effectiveTime" ] ;
       fhir:sliceName [ fhir:v "effectiveTimeFrequence" ] ;
       fhir:short [ fhir:v "Fréquence d'administration" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "fr-operator-a" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "operator doit être A" ] ;
         fhir:expression [ fhir:v "operator = 'A'" ] ;
         fhir:source [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement>
         ]
       ] [
         fhir:key [ fhir:v "fr-effectiveTime-frequence-types" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "La fréquence doit être SXCM-TS, PIVL-TS, EIVL-TS ou SXPR-TS" ] ;
         fhir:expression [ fhir:v "is(SXCM_TS) or is(PIVL_TS) or is(EIVL_TS) or is(SXPR_TS)" ] ;
         fhir:source [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement>
         ]
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.routeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.routeCode" ] ;
       fhir:short [ fhir:v "Voie d'administration : Si la voie d'administration est connue, elle doit être indiquée (code et displayName). Si elle n'est pas connue, la raison pour laquelle elle est inconnue peut être décrite en utilisant l'attribut nullFlavor.Terminologie utilisée :  EDQM - Standard terms / classe ROA (Voie d'administration)" ] ;
       fhir:definition [ fhir:v "Voie d'administration" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.approachSiteCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.approachSiteCode" ] ;
       fhir:short [ fhir:v "Région anatomique d'administration : La région anatomique d'administration provient du JDV_HumanSubstanceAdministrationSite_CISIS (1.2.250.1.213.1.1.5.686) (Terminologie SNOMED CT 2.16.840.1.113883.6.96). Cet élément doit contenir une référence pointant sur l'élément correspondant de la partie narrative où la région anatomique est décrite." ] ;
       fhir:definition [ fhir:v "Région anatomique d'administration" ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "https://smt.esante.gouv.fr/fhir/ValueSet/jdv-human-substance-administration-site-cisis"^^xsd:anyURI ;
           fhir:l <https://smt.esante.gouv.fr/fhir/ValueSet/jdv-human-substance-administration-site-cisis>
         ]
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.approachSiteCode.originalText" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.approachSiteCode.originalText" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.approachSiteCode.originalText.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.approachSiteCode.originalText.reference" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity" ] ;
       fhir:short [ fhir:v "Dose à administrer : \r\n\nS'il n'y a pas de traitement, utiliser une valeur nullFlavor.\nS'il y a un traitement, les sous-éléments 'low' et 'high' permettent de fournir les doses minimales et maximales à administrer. Dans le cas où la dose est fixe, ces deux sous-éléments prendront les mêmes valeurs. Dans chaque élément 'low' et 'high', un élément 'translation' peut permettre de pointer sur l'élément de la partie narrative relative à cette information.\nDans le cas où l'on s'exprime en quantités indénombrables, l'unité doit être transmise. Les unités sont exprimées selon le système de codage UCUM.\nDans le cas où l'on s'exprime en quantités dénombrables (capsules, comprimés, gélules, etc.) l'unité ne doit pas être renseignée. A la place, on ajoute un champ 'translation' qui permet de pointer sur l'élément de la partie narrative relative à cette information." ] ;
       fhir:definition [ fhir:v "Dose à administrer" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity.low" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity.low" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity.low.translation" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity.low.translation" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity.low.translation.originalText" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity.low.translation.originalText" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity.low.translation.originalText.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity.low.translation.originalText.reference" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity.high" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity.high" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity.high.translation" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity.high.translation" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity.high.translation.originalText" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity.high.translation.originalText" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity.high.translation.originalText.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity.high.translation.originalText.reference" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity" ] ;
       fhir:short [ fhir:v "Rythme d'administration : \r\n\nLe rythme d'administration permet d'indiquer la quantité de produit à administrer par unité de temps.\nLes sous-éléments 'low' et 'high' permettent de fournir le rythme minimal et maximal de l'administration. Dans le cas où le rythme est fixe, ces deux sous-éléments prendront les mêmes valeurs.\nL'argument @value permet d'indiquer la quantité de produit à administrer.\nL'argument @unit permet d'indiquer le rythme d'administration en combinant l'unité de quantité et l'unité de temps (séparés par le caractère ‘/'). Les unités sont exprimées selon le système de codage UCUM.\nDans chaque élément 'low' et 'high', un élément 'translation' peut permettre de pointer sur l'élément de la partie narrative relative à cette information." ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.nullFlavor" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.nullFlavor" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.low" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.low" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.low.translation" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.low.translation" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.low.translation.originalText" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.low.translation.originalText" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.low.translation.originalText.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.low.translation.originalText.reference" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.high" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.high" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.high.translation" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.high.translation" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.high.translation.originalText" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.high.translation.originalText" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity.high.translation.originalText.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity.high.translation.originalText.reference" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.maxDoseQuantity" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.maxDoseQuantity" ] ;
       fhir:short [ fhir:v "Dose maximale à administrer : \r\n\nLa dose maximale à 'maxDoseQuantity' permet d'indiquer la quantité maximale de produit à administrer par unité de temps.\nPlusieurs occurrences de 'maxDoseQuantity' peuvent être utilisées pour indiquer différentes limites sur différentes périodes de temps.\nLes sous-éléments 'numerator' et 'denominator' permettent de fournir :\n- numerator : la quantité maximale à administrer,\n- denominator : la plage de temps sur laquelle s'applique ce maximum.\nLes unités sont exprimées selon le système de codage UCUM." ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.maxDoseQuantity.numerator" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.maxDoseQuantity.numerator" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.maxDoseQuantity.numerator.unit" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.maxDoseQuantity.numerator.unit" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.maxDoseQuantity.numerator.value" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.maxDoseQuantity.numerator.value" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.maxDoseQuantity.denominator" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.maxDoseQuantity.denominator" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.maxDoseQuantity.denominator.unit" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.maxDoseQuantity.denominator.unit" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.maxDoseQuantity.denominator.value" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.maxDoseQuantity.denominator.value" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable" ] ;
       fhir:short [ fhir:v "Médicament" ] ;
       fhir:definition [ fhir:v "Médicament" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/ManufacturedProduct"^^xsd:anyURI ;
           fhir:l <http://hl7.org/cda/stds/core/StructureDefinition/ManufacturedProduct>
         ] ;
         fhir:profile ( [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-produit-de-sante"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-produit-de-sante>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:slicing [
         fhir:discriminator ( [
           fhir:type [ fhir:v "value" ] ;
           fhir:path [ fhir:v "$this" ]
         ] ) ;
         fhir:rules [ fhir:v "open" ]
       ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frPrescription" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:sliceName [ fhir:v "frPrescription" ] ;
       fhir:short [ fhir:v "Prescription" ] ;
       fhir:definition [ fhir:v "Prescription" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frPrescription.typeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "REFR"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frPrescription.supply" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.supply" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/Supply"^^xsd:anyURI ;
           fhir:l <http://hl7.org/cda/stds/core/StructureDefinition/Supply>
         ] ;
         fhir:profile ( [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-prescription"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-prescription>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frTraitementSubordonne" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:sliceName [ fhir:v "frTraitementSubordonne" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frTraitementSubordonne.typeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "COMP"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frTraitementSubordonne.sequenceNumber" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.sequenceNumber" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frTraitementSubordonne.substanceAdministration" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.substanceAdministration" ] ;
       fhir:short [ fhir:v "Traitement subordonné : \r\n\nUne entrée Traitement de premier niveau peut contenir une ou plusieurs sous-entrées 'Traitement' subordonnées pour les cas spécifiques des dosages progressifs, fractionnés ou conditionnels, ou pour gérer la combinaison de médicaments.\nL'utilisation de sous-entrées 'Traitement' subordonnées pour traiter ces cas est facultative. Dans ce cas, l'information doit être fournie dans la partie narrative de l'entrée 'Traitement' de premier niveau sous forme de texte libre." ] ;
       fhir:definition [ fhir:v "Traitement subordonné" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/SubstanceAdministration"^^xsd:anyURI ;
           fhir:l <http://hl7.org/cda/stds/core/StructureDefinition/SubstanceAdministration>
         ] ;
         fhir:profile ( [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement-subordonne"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-traitement-subordonne>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frInstructionsAuPatient" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:sliceName [ fhir:v "frInstructionsAuPatient" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frInstructionsAuPatient.typeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "SUBJ"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frInstructionsAuPatient.inversionInd" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.inversionInd" ] ;
       fhir:pattern [
         a fhir:Boolean ;
         fhir:v true
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frInstructionsAuPatient.act" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.act" ] ;
       fhir:short [ fhir:v "Instruction au patient : \r\n\nLes instructions au patient peuvent être transmises, sous forme textuelle, dans une entrée Instructions au patient (Patient Medication Instructions – 1.3.6.1.4.1.19376.1.5.3.1.4.3) portée par un élément \"entryRelationship\"." ] ;
       fhir:definition [ fhir:v "Instructions au patient" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/Act"^^xsd:anyURI ;
           fhir:l <http://hl7.org/cda/stds/core/StructureDefinition/Act>
         ] ;
         fhir:profile ( [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-instructions-au-patient"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-instructions-au-patient>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frReferenceInterne" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:sliceName [ fhir:v "frReferenceInterne" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frReferenceInterne.typeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "RSON"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frReferenceInterne.act" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.act" ] ;
       fhir:short [ fhir:v "Motif du traitement : \r\n\nLe motif du traitement (ou raison de l'administration) peut être indiqué en faisant référence à autre entrée du document CDA constituant ce motif (par exemple une entrée Problème).\nDans l'élément 'act' de l'entryRelationship :\n- L'attribut @actCode='ACT'\n- L'attribut @moodCode='EVN'\n- L'élément 'id' de l'élément référencé est repris à l'identique dans les entrées à lier\n- L'élément 'code' doit concorder avec celui utilisé par l'élément de référence." ] ;
       fhir:definition [ fhir:v "Motif du traitement" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/Act"^^xsd:anyURI ;
           fhir:l <http://hl7.org/cda/stds/core/StructureDefinition/Act>
         ] ;
         fhir:profile ( [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-reference-interne"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-reference-interne>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.precondition" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.precondition" ] ;
       fhir:short [ fhir:v "Précondition : \r\n\nPermet de décrire les conditions préalables à l'utilisation du médicament.      L'attribut @value de l'élément 'reference' est une URI qui pointe vers la partie narrative du document CDA décrivant ces conditions préalables. " ] ;
       fhir:definition [ fhir:v "Précondition" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.precondition.criterion" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.precondition.criterion" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.precondition.criterion.text" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.precondition.criterion.text" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] )
  ] . # 

