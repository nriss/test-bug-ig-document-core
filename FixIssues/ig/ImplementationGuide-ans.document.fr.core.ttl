       ] ;
       fhir:name [ fhir:v "CDA - representedOrganization" ] ;
       fhir:description [ fhir:v "L'élément de l'en-tête du CDA representedOrganization permet de représenter la structure pour le compte de laquelle intervient le professionnel." ] ;
