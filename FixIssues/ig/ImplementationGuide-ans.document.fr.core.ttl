       ] ;
       fhir:name [ fhir:v "CDA - FR Instruction au patient" ] ;
       fhir:description [ fhir:v "Entrée FR-Instruction-au-patient: IHE-PCC - Simple-Observation. Cette entrée permet d’enregistrer une instruction au patient sous forme codée (c’est notamment le cas pour les prescriptions d’examens de biologie médicale)." ] ;
