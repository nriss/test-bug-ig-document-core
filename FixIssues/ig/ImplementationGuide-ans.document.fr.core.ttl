       ] ;
       fhir:name [ fhir:v "CDA - FR Code a barres" ] ;
       fhir:description [ fhir:v "Cette section permet d'enregistrer des codes à barres" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps des sections" ]
     ] [
       fhir:extension ( [
