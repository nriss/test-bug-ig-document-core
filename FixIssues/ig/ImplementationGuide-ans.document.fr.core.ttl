       ] ;
       fhir:name [ fhir:v "DiagnosticReport - FR Diagnostic Report Document" ] ;
       fhir:description [ fhir:v "FRDiagnosticReportDocument est un profil permettant de regrouper les types des résultats classés par type d’examens (BIO, IMG, etc…)." ] ;
       fhir:example [
