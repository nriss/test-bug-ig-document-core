       ] ;
       fhir:name [ fhir:v "CDA - FR Traitement dispense" ] ;
       fhir:description [ fhir:v "Entrée FR-Traitement-dispense: IHE PHARM DIS - DispenseItemEntry. Cette entrée de type supply permet de décrire un traitement dispensé avec notamment le médicament dispensé, la quantité et la référence de la prescription." ] ;
