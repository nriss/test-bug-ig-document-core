       ] ;
       fhir:name [ fhir:v "CDA - FR Autorisation Substitution" ] ;
       fhir:description [ fhir:v "Entrée FR-Autorisation-Substitution: IHE-PRE - Substitution-Permission. Cette observation permet d'indiquer si le traitement auquel elle est associée peut être substitué." ] ;
