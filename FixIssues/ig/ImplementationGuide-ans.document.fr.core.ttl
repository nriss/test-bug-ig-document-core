       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-sujet-non-humain> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-sujet-non-humain" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Sujet non humain" ] ;
       fhir:description [ fhir:v "Entrée FR-Sujet-non-humain: IHE-PCC - Non-Human Subject \n - Cet élément doit être présent lorsque le sujet des observations du compte rendu est un échantillon provenant d'un sujet non humain (animal ou autre élément environnemental) analysé par un laboratoire de biologie médicale dans le cadre d'une investigation sur un patient. Le sujet non humain doit aussi être décrit dans l'en-tête du document." ] ;
