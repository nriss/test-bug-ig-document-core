       ] ;
       fhir:name [ fhir:v "DiagnosticReport - FR Diagnostic Report Imaging Document" ] ;
       fhir:description [ fhir:v "Le profil FRDiagnosticReportImagingDocument est dédié aux comptes rendus d’imagerie.\nCe document représente le rapport d’un examen d’imagerie. Il constitue la ressource principale qui fait référence à l’ensemble des données produites lors de l’examen d’imagerie." ] ;
