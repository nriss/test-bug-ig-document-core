         fhir:reference [ fhir:v "StructureDefinition/cisis-telecom" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR CISIS Telecom" ] ;
       fhir:description [ fhir:v "Coordonnées télécom : \n - Exemples :\n<telecom value='tel:0147150000' use='H'/>\n<telecom value='mailto:adam.homme@fournisseur.fr'/>\n<telecom value='ftp://serveur/dossierdesante/exemple/'/>" ] ;
