       fhir:short [ fhir:v "Date de fin de la participation" ] ;
       fhir:definition [ fhir:v "Date de fin de la participation" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Participant2.participantRole" ] ;
