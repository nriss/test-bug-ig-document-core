         ] )
       ] ) ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Participant2.participantRole.playingDevice" ] ;
       fhir:path [ fhir:v "Participant2.participantRole.playingDevice" ] ;
       fhir:short [ fhir:v "Dispositif automatique : \r\n\n  Si typeCode='DEV' : l'entité qui tient le rôle est un dispositif automatique (l'élément playingDevice est alors obligatoire).\n  Dans ce cas, l'un des trois sous-éléments code, manufacturerModelName, softwareName doit être renseigné." ] ;
       fhir:definition [ fhir:v "Dispositif automatique" ] ;
