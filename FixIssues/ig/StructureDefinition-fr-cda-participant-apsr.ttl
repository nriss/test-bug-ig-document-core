       fhir:definition [ fhir:v "Rôle du participant" ] ;
       fhir:mustSupport [ fhir:v true ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "https://smt.esante.gouv.fr/fhir/ValueSet/jdv-participant-additionnel-resultat-cisis"^^xsd:anyURI ;
           fhir:l <https://smt.esante.gouv.fr/fhir/ValueSet/jdv-participant-additionnel-resultat-cisis>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Participant2.time" ] ;
