       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Participant2.participantRole.id" ] ;
       fhir:path [ fhir:v "Participant2.participantRole.id" ] ;
       fhir:short [ fhir:v "Identifiant du participant" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Participant2.participantRole.addr" ] ;
       fhir:path [ fhir:v "Participant2.participantRole.addr" ] ;
       fhir:short [ fhir:v "Adresses du participant" ] ;
       fhir:type ( [
         fhir:code [
