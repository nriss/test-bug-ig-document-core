     ] [
       fhir:id [ fhir:v "Supply.effectiveTime" ] ;
       fhir:path [ fhir:v "Supply.effectiveTime" ] ;
       fhir:short [ fhir:v "- Si la période de renouvellement est définie à partir d'une date précise, utiliser les éléments <low> et <high> avec l'élément <high> (date de fin) obligatoire et l'élément <low> (date de début) facultatif.\n- Si la période de renouvellement est définie par une durée, utiliser les éléments <low> et <width> avec  l'élément <width> (période de temps) obligatoire et l'élément <low> (date de début) facultatif." ] ;
       fhir:definition [ fhir:v "Période de renouvellement" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "fr-effectiveTime-type" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "La durée doit être IVL-TS" ] ;
         fhir:expression [ fhir:v "is(IVL_TS)" ] ;
         fhir:source [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-periode-de-renouvellement"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-periode-de-renouvellement>
         ]
       ] [
         fhir:key [ fhir:v "fr-inv-effectiveTime" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Soit high, soit width doit être présent, mais pas les deux" ] ;
         fhir:expression [ fhir:v "(high.exists() xor width.exists())" ] ;
         fhir:source [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-periode-de-renouvellement"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-periode-de-renouvellement>
         ]
       ] ) ;
       fhir:mustSupport [ fhir:v true ]
     ] )
  ] . # 

