       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.nullFlavor" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.nullFlavor" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "NA"
       ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.author" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.author" ] ;
       fhir:short [ fhir:v "Auteur de la ligne de traitement" ] ;
       fhir:definition [ fhir:v "Auteur de la ligne de traitement" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/Author"^^xsd:anyURI ;
           fhir:l <http://hl7.org/cda/stds/core/StructureDefinition/Author>
         ] ;
         fhir:profile ( [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-author"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-author>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:short [ fhir:v "Item d'un plan de traitement. Copie non modifiée de la ligne de traitement référencée." ] ;
       fhir:definition [ fhir:v "Item d'un plan de traitement" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship.typeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "REFR"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship.substanceAdministration" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.substanceAdministration" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/SubstanceAdministration"^^xsd:anyURI ;
           fhir:l <http://hl7.org/cda/stds/core/StructureDefinition/SubstanceAdministration>
         ] ;
         fhir:profile ( [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-item-plan-traitement"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-item-plan-traitement>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.reference" ] ;
       fhir:short [ fhir:v "Identifiant du plan de traitement. Cet identifiant peut faciliter la recherche du plan de traitement d'origine si nécessaire." ] ;
       fhir:definition [ fhir:v "Identifiant du plan de traitement" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.reference.typeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.reference.typeCode" ] ;
