           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-commentaire-er>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frDoseAntigene" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:sliceName [ fhir:v "frDoseAntigene" ] ;
       fhir:short [ fhir:v "Dose d'antigène : \r\n\nUn des cas d'utilisation est la vaccination de sujets hypersensibles [https ://professionnels.vaccination-info-service.fr/Aspects-pratiques/Allergies-et-autres-contre-indications/Personnes-allergiques]" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ]
