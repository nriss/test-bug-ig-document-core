         a fhir:Code ;
         fhir:v "CAUS"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frProbleme.inversionInd" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.inversionInd" ] ;
       fhir:pattern [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frProbleme.observation" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.observation" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/Observation"^^xsd:anyURI ;
           fhir:l <http://hl7.org/cda/stds/core/StructureDefinition/Observation>
         ] ;
         fhir:profile ( [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-probleme"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-probleme>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frCommentaireER" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:sliceName [ fhir:v "frCommentaireER" ] ;
       fhir:short [ fhir:v "Commentaire" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frCommentaireER.typeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
