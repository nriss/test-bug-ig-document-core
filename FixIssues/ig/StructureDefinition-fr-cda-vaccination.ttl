         ] )
       ] )
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.performer" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.performer" ] ;
       fhir:short [ fhir:v "Exécutant" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "http://hl7.org/cda/stds/core/StructureDefinition/Performer2"^^xsd:anyURI ;
