       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.code" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.code" ] ;
       fhir:short [ fhir:v "Type de vaccination : \r\n\n JDV_HL7_ActSubstanceAdministrationImmunizationCode_CISIS (2.16.840.1.113883.1.11.19709). \n Il permet d’indiquer si l’entrée concerne une vaccination :\n - de 1ère série vaccinante ('INITIMMUNIZ') de rappel ('BOOSTER') vaccination sans autre précision ('IMMUNIZ') \n - de rappel ('BOOSTER') \n - vaccination sans autre précision ('IMMUNIZ') \n OR \n JDV_AbsentOrUnknownImmunization_CISIS (1.2.250.1.213.1.1.5.666)" ] ;
       fhir:definition [ fhir:v "Type de vaccination" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ] ;
