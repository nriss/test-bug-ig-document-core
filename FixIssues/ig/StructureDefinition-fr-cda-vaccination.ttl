     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frPrescription" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship" ] ;
       fhir:sliceName [ fhir:v "frPrescription" ] ;
       fhir:short [ fhir:v "Prescription" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frPrescription.typeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "REFR"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.entryRelationship:frPrescription.supply" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.entryRelationship.supply" ] ;
