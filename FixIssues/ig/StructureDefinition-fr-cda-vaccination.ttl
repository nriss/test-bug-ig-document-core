         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "https://interop.esante.gouv.fr/ig/document/core/ValueSet/fr-valueset-type-vaccination"^^xsd:anyURI ;
           fhir:l <https://interop.esante.gouv.fr/ig/document/core/ValueSet/fr-valueset-type-vaccination>
         ]
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.code.code" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.code.code" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
