       fhir:short [ fhir:v "Date de la vaccination : \r\n\nSi la date de la vaccination est inconnue, utiliser une valeur nullFlavor précisant la raison pour laquelle la date n'est pas connue." ] ;
       fhir:definition [ fhir:v "Date de la vaccination" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
