           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/xml-name>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "inFulfillmentOf1"
         ]
       ] ) ;
       fhir:path [ fhir:v "SubstanceAdministration.sdtcInFulfillmentOf1" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
