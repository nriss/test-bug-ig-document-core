         fhir:discriminator ( [
           fhir:type [ fhir:v "value" ] ;
           fhir:path [ fhir:v "root" ]
         ] ) ;
         fhir:rules [ fhir:v "open" ]
       ] ;
       fhir:min [ fhir:v "2"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "2" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:frDicomAdministrationProduitDeSante" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "frDicomAdministrationProduitDeSante" ] ;
       fhir:short [ fhir:v "Conformité FR-DICOM-Administration-produit-de-sante (CI-SIS)" ] ;
       fhir:definition [ fhir:v "Conformité FR-DICOM-Administration-produit-de-sante (CI-SIS)" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:frDicomAdministrationProduitDeSante.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.2.250.1.213.1.1.3.151"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:dicomProceduralMedication" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId" ] ;
       fhir:sliceName [ fhir:v "dicomProceduralMedication" ] ;
       fhir:short [ fhir:v "Conformité Procedural Medication (DICOM Part 20)" ] ;
       fhir:definition [ fhir:v "Conformité Procedural Medication (DICOM Part 20)" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.templateId:dicomProceduralMedication.root" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.2.840.10008.9.13"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.classCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.classCode" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.moodCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.moodCode" ] ;
       fhir:short [ fhir:v "- Si le traitement a déjà été administré ou si information rapportée par le patient ou si aucun traitement : moodCode='EVN'  \n- Si le traitement est en attente d'administration : moodCode='INT'" ] ;
       fhir:definition [ fhir:v "- Si le traitement a déjà été administré ou si information rapportée par le patient ou si aucun traitement : moodCode='EVN'  \n- Si le traitement est en attente d'administration : moodCode='INT'" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.id" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.id" ] ;
       fhir:short [ fhir:v "Identifiant de l'entrée" ] ;
       fhir:definition [ fhir:v "Identifiant de l'entrée" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.text" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.text" ] ;
       fhir:short [ fhir:v "Partie narrative de l'entrée" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.text.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.text.reference" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.statusCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.statusCode" ] ;
       fhir:short [ fhir:v "Status de l'entrée" ] ;
       fhir:definition [ fhir:v "Status de l'entrée" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.statusCode.code" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.statusCode.code" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "completed"
       ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.routeCode" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.routeCode" ] ;
       fhir:short [ fhir:v "Voie d'administration Terminologie utilisée :  EDQM - Standard terms / classe ROA (Voie d'administration)" ] ;
       fhir:definition [ fhir:v "Voie d'administration" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.doseQuantity" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.doseQuantity" ] ;
       fhir:short [ fhir:v "Dose à administrer. S'il n'y a pas de traitement, utiliser une valeur nullFlavor.\nS'il y a un traitement, les sous-éléments 'low' et 'high' permettent de fournir les doses minimales et maximales à administrer. Dans le cas où la dose est fixe, ces deux sous-éléments prendront les mêmes valeurs. Dans chaque élément 'low' et 'high', un élément 'translation' peut permettre de pointer sur l'élément de la partie narrative relative à cette information.\nDans le cas où l'on s'exprime en quantités indénombrables, l'unité doit être transmise. Les unités sont exprimées selon le système de codage UCUM.\nDans le cas où l'on s'exprime en quantités dénombrables (capsules, comprimés, gélules, etc.) l'unité ne doit pas être renseignée. A la place, on ajoute un champ 'translation' qui permet de pointer sur l'élément de la partie narrative relative à cette information." ] ;
       fhir:definition [ fhir:v "Dose à administrer" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.rateQuantity" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.rateQuantity" ] ;
       fhir:short [ fhir:v "Rythme d'administration.\nLe rythme d'administration permet d'indiquer la quantité de produit à administrer par unité de temps.\nLes sous-éléments 'low' et 'high' permettent de fournir le rythme minimal et maximal de l'administration. Dans le cas où le rythme est fixe, ces deux sous-éléments prendront les mêmes valeurs.\nL'argument @value permet d'indiquer la quantité de produit à administrer.\nL'argument @unit permet d'indiquer le rythme d'administration en combinant l'unité de quantité et l'unité de temps (séparés par le caractère ‘/'). Les unités sont exprimées selon le système de codage UCUM.\nDans chaque élément 'low' et 'high', un élément 'translation' peut permettre de pointer sur l'élément de la partie narrative relative à cette information." ] ;
       fhir:definition [ fhir:v "Rythme d'administration" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable" ] ;
       fhir:short [ fhir:v "Médicament" ] ;
       fhir:definition [ fhir:v "Médicament" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct" ] ;
       fhir:short [ fhir:v "Produit de santé" ] ;
       fhir:definition [ fhir:v "Produit de santé" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.code" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.code" ] ;
       fhir:short [ fhir:v "Choix parmi les éléments suivants: code et nullFlavor. \n      Code du produit de santé. \n      - CIP : Code Identifiant de Présentation (1.2.250.1.213.2.3.2)\n      - UCD : Unités Communes de Dispensation (1.2.250.1.213.2.61) \n      + code ATC" ] ;
       fhir:definition [ fhir:v "Code du produit de santé" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.code.originalText" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.code.originalText" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.code.originalText.reference" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.code.originalText.reference" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.code.translation" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.code.translation" ] ;
       fhir:short [ fhir:v "- ATC : Classification anatomique, thérapeutique et chimique (2.16.840.1.113883.6.73)\n- CIS : Code Identifiant de Spécialité (1.2.250.1.213.2.3.1)\n- MV : Médicament Virtuel (1.2.250.1.213.2.59) de Medicabase" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.name" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.name" ] ;
       fhir:short [ fhir:v "Nom de marque du produit" ] ;
       fhir:definition [ fhir:v "Nom de marque du produit" ]
     ] [
       fhir:id [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.lotNumberText" ] ;
       fhir:path [ fhir:v "SubstanceAdministration.consumable.manufacturedProduct.manufacturedMaterial.lotNumberText" ] ;
       fhir:short [ fhir:v "Numéro de lot" ] ;
       fhir:definition [ fhir:v "Numéro de lot" ]
     ] )
  ] . # 

