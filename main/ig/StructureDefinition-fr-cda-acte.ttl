     ] [
       fhir:id [ fhir:v "Procedure.text" ] ;
       fhir:path [ fhir:v "Procedure.text" ] ;
       fhir:short [ fhir:v "Description narrative de l'acte" ] ;
       fhir:definition [ fhir:v "Description narrative de l'acte" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.text.reference" ] ;
       fhir:path [ fhir:v "Procedure.text.reference" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.statusCode" ] ;
       fhir:path [ fhir:v "Procedure.statusCode" ] ;
       fhir:short [ fhir:v "Statut de l'acte : \r\n\nutiliser le jdv-hl7-v3-ActStatus-cisis (2.16.840.1.113883.1.11.15933 ) \n- Si l'acte a été réalisé : le statut prend la valeur 'completed'. \n- Si l'acte a été arrêté avant sa fin : le statut prend la valeur 'aborted'. \n- Si l'acte a été annulé avant sa réalisation : le statut prend la valeur 'cancelled'. \n- Si l'acte est en cours ou à venir : le statut prend la valeur 'active'." ] ;
       fhir:definition [ fhir:v "Statut de l'acte" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "https://smt.esante.gouv.fr/fhir/ValueSet/jdv-hl7-v3-ActStatus-cisis"^^xsd:anyURI ;
           fhir:l <https://smt.esante.gouv.fr/fhir/ValueSet/jdv-hl7-v3-ActStatus-cisis>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Procedure.effectiveTime" ] ;
       fhir:path [ fhir:v "Procedure.effectiveTime" ] ;
       fhir:short [ fhir:v "Date de l'acte : \r\n\n- Si l'acte a été réalisé : l'élément 'effectiveTime' indique la date de réalisation. \n- Si l'acte a été annulé (statusCode 'Cancelled') ou arrêté (statusCode 'aborted'), l'élément 'effectiveTime' peut garder sa valeur initiale si elle était renseignée. \n- Si l'acte est prévu : l'élément 'effectiveTime' indique la date de planification si elle est connue ou la prend la valeur nullflavor='UNK' si elle n'est pas connue." ] ;
       fhir:definition [ fhir:v "Date de l'acte" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.priorityCode" ] ;
       fhir:path [ fhir:v "Procedure.priorityCode" ] ;
       fhir:short [ fhir:v "Priorité : \r\n \nutiliser le jdv-hl7-v3-ActPriority-cisis (2.16.840.1.113883.1.11.16866) ou autre." ] ;
       fhir:definition [ fhir:v "Priorité" ]
     ] [
       fhir:id [ fhir:v "Procedure.approachSiteCode" ] ;
       fhir:path [ fhir:v "Procedure.approachSiteCode" ] ;
       fhir:short [ fhir:v "Voie d’abord : \r\n\nnon renseigné si la voie d'abord est contenue dans le code de l'acte (comme c'est le cas avec la CCAM).\nSinon, utiliser la codification SNOMED CT (2.16.840.1.113883.6.96)" ] ;
