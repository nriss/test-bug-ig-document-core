       fhir:path [ fhir:v "Procedure.moodCode" ] ;
       fhir:short [ fhir:v "- Si acte prévu : moodCode='INT' ; negationInd='false' (valeur par défaut) \n- Si acte réalisé : moodCode='EVN' ; negationInd='true' \n    - si l'acte n'a pas eu lieu : negationInd='false' \n    - si l'acte a eu lieu (valeur par défaut)" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.id" ] ;
       fhir:path [ fhir:v "Procedure.id" ] ;
       fhir:short [ fhir:v "Identifiant de l'entrée" ] ;
       fhir:definition [ fhir:v "Identifiant de l'entrée" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.code" ] ;
       fhir:path [ fhir:v "Procedure.code" ] ;
       fhir:short [ fhir:v "Code d'acte : \r\n\nAussi utilisé pour indiquer qu'il n'y a pas d'acte, ou qu'on ne sait pas s'il y en a.\nTerminologie CCAM (1.2.250.1.215.300.1) si possible. \nSi l'acte n'est pas trouvé dans la terminologie CCAM, utiliser le code='C25218' displayName='Intervention' codeSystem='2.16.840.1.113883.3.26.1.1' codeSystemName='NCIT' et décrire l'acte sous forme de texte libre dans la partie narrative avec une référence vers l'entrée correspondante \nou jdv-absent-or-unknown-procedure-cisis (1.2.250.1.213.1.1.5.665) pour les actes chirurgicaux" ] ;
       fhir:definition [ fhir:v "Code d'acte" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.code.code" ] ;
       fhir:path [ fhir:v "Procedure.code.code" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.code.codeSystem" ] ;
       fhir:path [ fhir:v "Procedure.code.codeSystem" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
